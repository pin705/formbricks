generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USER — mirrors Supabase auth.users
// ─────────────────────────────────────────────
model User {
  id        String   @id // = supabase auth.users.id (uuid)
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspaces WorkspaceMember[]
  links      Link[]
  auditLogs  AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────────
// WORKSPACE — tenant, owned by a user
// ─────────────────────────────────────────────
model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String   @map("owner_id") // references User.id
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members       WorkspaceMember[]
  links         Link[]
  campaigns     Campaign[]
  domains       Domain[]
  subscription  Subscription?
  usageCounters UsageCounter[]
  auditLogs     AuditLog[]

  @@index([ownerId])
  @@map("workspaces")
}

// ─────────────────────────────────────────────
// WORKSPACE MEMBER — user ↔ workspace join
// ─────────────────────────────────────────────
model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("member") // owner | admin | member
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

// ─────────────────────────────────────────────
// PLAN
// ─────────────────────────────────────────────
model Plan {
  id                     String  @id @default(cuid())
  name                   String  @unique // free | pro | team | agency
  maxLinks               Int     @map("max_links")
  maxClicksPerMonth      Int     @map("max_clicks_per_month")
  maxDomains             Int     @map("max_domains")
  maxMembers             Int     @map("max_members")
  analyticsRetentionDays Int     @map("analytics_retention_days")
  hasCustomSlugs         Boolean @default(false) @map("has_custom_slugs")
  hasPasswordProtect     Boolean @default(false) @map("has_password_protect")
  hasLinkExpiry          Boolean @default(false) @map("has_link_expiry")
  hasAdvancedAnalytics   Boolean @default(false) @map("has_advanced_analytics")
  hasCustomQr            Boolean @default(false) @map("has_custom_qr")
  hasApiAccess           Boolean @default(false) @map("has_api_access")
  hasCsvExport           Boolean @default(false) @map("has_csv_export")
  stripePriceId          String? @map("stripe_price_id")

  subscriptions Subscription[]

  @@map("plans")
}

// ─────────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────────
model Subscription {
  id                   String   @id @default(cuid())
  workspaceId          String   @unique @map("workspace_id")
  planId               String   @map("plan_id")
  stripeCustomerId     String?  @map("stripe_customer_id")
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  status               String   @default("active")
  currentPeriodStart   DateTime @map("current_period_start")
  currentPeriodEnd     DateTime @map("current_period_end")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id])

  @@index([workspaceId])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// DOMAIN
// ─────────────────────────────────────────────
model Domain {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  hostname    String   @unique
  dubDomainId String?  @map("dub_domain_id")
  isVerified  Boolean  @default(false) @map("is_verified")
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links     Link[]

  @@index([workspaceId])
  @@map("domains")
}

// ─────────────────────────────────────────────
// CAMPAIGN
// ─────────────────────────────────────────────
model Campaign {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  name        String
  color       String    @default("#6366f1")
  description String?
  dubTagId    String?   @map("dub_tag_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  archivedAt  DateTime? @map("archived_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links     Link[]

  @@index([workspaceId])
  @@map("campaigns")
}

// ─────────────────────────────────────────────
// LINK
// ─────────────────────────────────────────────
model Link {
  id             String    @id @default(cuid())
  workspaceId    String    @map("workspace_id")
  domainId       String?   @map("domain_id")
  campaignId     String?   @map("campaign_id")
  createdByUserId String   @map("created_by_user_id") // references User.id
  destinationUrl String    @map("destination_url")
  slug           String
  dubLinkId      String?   @unique @map("dub_link_id")
  shortUrl       String?   @map("short_url")
  isActive       Boolean   @default(true) @map("is_active")
  title          String?
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  domain    Domain?   @relation(fields: [domainId], references: [id], onDelete: SetNull)
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  creator   User      @relation(fields: [createdByUserId], references: [id])

  @@unique([slug, domainId])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, campaignId])
  @@index([dubLinkId])
  @@map("links")
}

// ─────────────────────────────────────────────
// USAGE COUNTER
// ─────────────────────────────────────────────
model UsageCounter {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  period       String // "2026-04"
  linksCreated Int      @default(0) @map("links_created")
  domainsAdded Int      @default(0) @map("domains_added")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, period])
  @@index([workspaceId, period])
  @@map("usage_counters")
}

// ─────────────────────────────────────────────
// DAILY CLICK SUMMARY
// ─────────────────────────────────────────────
model DailyClickSummary {
  id             String   @id @default(cuid())
  linkId         String   @map("link_id")
  workspaceId    String   @map("workspace_id")
  date           DateTime @db.Date
  country        String?
  deviceType     String?  @map("device_type")
  referrerDomain String?  @map("referrer_domain")
  clickCount     Int      @default(0) @map("click_count")

  @@unique([linkId, date, country, deviceType, referrerDomain])
  @@index([workspaceId, date(sort: Desc)])
  @@index([linkId, date(sort: Desc)])
  @@map("daily_click_summaries")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────
model AuditLog {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  actorUserId  String   @map("actor_user_id")
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User      @relation(fields: [actorUserId], references: [id])

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("audit_logs")
}
