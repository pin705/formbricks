generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// WORKSPACE (tenant = Clerk Organization)
// Identity owned by Clerk — we mirror id + name
// ─────────────────────────────────────────────
model Workspace {
  id        String   @id // = clerk_org_id
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  links         Link[]
  campaigns     Campaign[]
  domains       Domain[]
  subscription  Subscription?
  usageCounters UsageCounter[]
  auditLogs     AuditLog[]

  @@map("workspaces")
}

// ─────────────────────────────────────────────
// PLAN
// ─────────────────────────────────────────────
model Plan {
  id                     String  @id @default(cuid())
  name                   String  @unique // free | pro | team | agency
  maxLinks               Int     @map("max_links")
  maxClicksPerMonth      Int     @map("max_clicks_per_month")
  maxDomains             Int     @map("max_domains")
  maxMembers             Int     @map("max_members")
  analyticsRetentionDays Int     @map("analytics_retention_days")
  hasCustomSlugs         Boolean @default(false) @map("has_custom_slugs")
  hasPasswordProtect     Boolean @default(false) @map("has_password_protect")
  hasLinkExpiry          Boolean @default(false) @map("has_link_expiry")
  hasAdvancedAnalytics   Boolean @default(false) @map("has_advanced_analytics")
  hasCustomQr            Boolean @default(false) @map("has_custom_qr")
  hasApiAccess           Boolean @default(false) @map("has_api_access")
  hasCsvExport           Boolean @default(false) @map("has_csv_export")
  stripePriceId          String? @map("stripe_price_id")

  subscriptions Subscription[]

  @@map("plans")
}

// ─────────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────────
model Subscription {
  id                   String   @id @default(cuid())
  workspaceId          String   @unique @map("workspace_id")
  planId               String   @map("plan_id")
  stripeCustomerId     String?  @map("stripe_customer_id")
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  status               String   @default("active") // active | past_due | canceled | trialing
  currentPeriodStart   DateTime @map("current_period_start")
  currentPeriodEnd     DateTime @map("current_period_end")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id])

  @@index([workspaceId])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// DOMAIN
// Mirrored from Dub — we store for UI + workspace scoping
// ─────────────────────────────────────────────
model Domain {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  hostname    String   @unique
  dubDomainId String?  @map("dub_domain_id") // Dub's domain identifier
  isVerified  Boolean  @default(false) @map("is_verified")
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links     Link[]

  @@index([workspaceId])
  @@map("domains")
}

// ─────────────────────────────────────────────
// CAMPAIGN
// Maps to Dub "tags" — we own the entity, tag by campaign name
// ─────────────────────────────────────────────
model Campaign {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  name        String
  color       String    @default("#6366f1")
  description String?
  dubTagId    String?   @map("dub_tag_id") // Dub tag id
  createdAt   DateTime  @default(now()) @map("created_at")
  archivedAt  DateTime? @map("archived_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links     Link[]

  @@index([workspaceId])
  @@map("campaigns")
}

// ─────────────────────────────────────────────
// LINK
// Source of truth for workspace scoping + campaign/domain assignment.
// dubLinkId is the Dub link id — used for analytics + redirect.
// ─────────────────────────────────────────────
model Link {
  id              String    @id @default(cuid())
  workspaceId     String    @map("workspace_id")
  domainId        String?   @map("domain_id")
  campaignId      String?   @map("campaign_id")
  createdByUserId String    @map("created_by_user_id") // clerk_user_id
  destinationUrl  String    @map("destination_url")
  slug            String
  dubLinkId       String?   @unique @map("dub_link_id") // Dub's link id
  shortUrl        String?   @map("short_url") // e.g. https://dub.sh/abc or custom domain
  isActive        Boolean   @default(true) @map("is_active")
  title           String?
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  domain    Domain?   @relation(fields: [domainId], references: [id], onDelete: SetNull)
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, campaignId])
  @@index([dubLinkId])
  @@map("links")
}

// ─────────────────────────────────────────────
// USAGE COUNTER (fast billing checks)
// Avoids expensive API calls for limit enforcement
// ─────────────────────────────────────────────
model UsageCounter {
  id            String   @id @default(cuid())
  workspaceId   String   @map("workspace_id")
  period        String // "2026-04" (YYYY-MM)
  linksCreated  Int      @default(0) @map("links_created")
  domainsAdded  Int      @default(0) @map("domains_added")
  updatedAt     DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, period])
  @@index([workspaceId, period])
  @@map("usage_counters")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────
model AuditLog {
  id               String   @id @default(cuid())
  workspaceId      String   @map("workspace_id")
  actorClerkUserId String   @map("actor_clerk_user_id")
  action           String // link.created | domain.verified | plan.upgraded
  resourceType     String?  @map("resource_type")
  resourceId       String?  @map("resource_id")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("audit_logs")
}
